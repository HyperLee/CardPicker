@page
@model CardPicker.Pages.Cards.DeleteModel
@{
    ViewData["Title"] = "刪除餐點卡牌";
}

<section class="library-page" aria-labelledby="delete-card-title">
    <header class="library-page__header">
        <h1 id="delete-card-title" class="library-page__title">刪除餐點卡牌</h1>
        <p class="library-page__subtitle">請再次確認卡牌內容，送出後將無法復原。</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.FailureMessage))
    {
        <section class="library-empty" aria-live="polite">
            <p class="mb-0">@Model.FailureMessage</p>
        </section>
    }

    @if (Model.Card is not null)
    {
        <section class="library-detail" aria-live="polite" aria-labelledby="delete-summary-title">
            <h2 id="delete-summary-title" class="library-detail__title">刪除確認摘要</h2>
            <h3 class="library-detail__name">@Model.Card.Name</h3>
            <dl class="library-detail__list">
                <div>
                    <dt>餐別</dt>
                    <dd>@DeleteModel.GetMealTypeLabel(Model.Card.MealType)</dd>
                </div>
                <div>
                    <dt>說明</dt>
                    <dd>@Model.Card.Description</dd>
                </div>
            </dl>
        </section>

        <form method="post" asp-page="/Cards/Delete" asp-route-id="@Model.CardId" class="library-search" aria-describedby="delete-form-help">
            <input type="hidden" name="id" value="@Model.CardId" />
            <p id="delete-form-help" class="library-search__intro">刪除後這張卡牌會從首頁抽卡、搜尋結果與後續啟動資料中移除。</p>

            <div class="form-check mb-3">
                <input
                    class="form-check-input"
                    id="confirmDelete"
                    name="confirmDelete"
                    type="checkbox"
                    value="true"
                    checked="@Model.ConfirmDelete"
                    aria-describedby="confirmDelete-help" />
                <label class="form-check-label" for="confirmDelete">
                    我已確認要刪除此餐點卡牌
                </label>
                <p id="confirmDelete-help" class="form-hint">請先勾選確認框，再送出刪除要求。</p>
            </div>

            <div class="library-search__actions">
                <button type="submit" class="btn btn-danger">確認刪除</button>
                <a asp-page="/Cards/Index" class="btn btn-outline-secondary">返回卡牌庫</a>
            </div>
        </form>
    }
</section>
