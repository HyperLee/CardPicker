@page
@using CardPicker.Models
@model CardPicker.Pages.Cards.CreateModel
@{
    ViewData["Title"] = "新增卡牌";
}

<section class="library-page">
    <header class="library-page__header">
        <h1 class="library-page__title">新增餐點卡牌</h1>
        <p class="library-page__subtitle">輸入餐點名稱、餐別與描述，將新卡牌加入卡牌庫。</p>
    </header>

    <form method="post" class="library-search" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="library-search__fields">
            <div>
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.MealType" class="form-label"></label>
                <select asp-for="Input.MealType" class="form-select">
                    <option value="">請選擇餐別</option>
                    <option value="@MealType.Breakfast">早餐</option>
                    <option value="@MealType.Lunch">午餐</option>
                    <option value="@MealType.Dinner">晚餐</option>
                </select>
                <span asp-validation-for="Input.MealType" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
        </div>

        <div class="library-search__actions">
            <button type="submit" class="btn btn-primary">儲存卡牌</button>
            <a asp-page="/Cards/Index" class="btn btn-outline-secondary">返回卡牌庫</a>
        </div>
    </form>
</section>
